  - speaker: 2
    speakerName: "\u0411\u0435\u043B\u044B\u0439 \u0431\u043E\u0433"
    text: "\u0421\u0440\u043E\u0447\u043D\u043E \u043D\u0430\u0434\u043E \u0440\u0430\u0441\u0441\u043A\u0430\u0437\u0430\u0442\u044C
      \u0442\u0440\u0443\u0445\u043B\u044F\u0432\u043E\u043C\u0443, \u0447\u0442\u043E
