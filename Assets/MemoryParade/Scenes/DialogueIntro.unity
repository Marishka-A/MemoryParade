  - speaker: 3
    speakerName: "\u0413\u0413"
    text: "\u0427\u0442\u043E \u044D\u0442\u043E?"
    background: {fileID: 21300000, guid: 41bff0e74cdc3af49a90b77ae5be31da, type: 3}
    leftPortrait: {fileID: 21300000, guid: dfde3493724dca44f8907cfe2bde76f9, type: 3}
    rightPortrait: {fileID: 21300000, guid: 9887c52db6846274593998508bd203de, type: 3}
    leftActive: 1
    rightActive: 0
    useFade: 0
    fadeDuration: 0.35
    shakeCamera: 0
    shakeDuration: 0.2
    shakeStrength: 8
    delayBeforeShow: 0
    actions: []
  - speaker: 2
    speakerName: "\u0411\u0435\u043B\u044B\u0439 \u0431\u043E\u0433"
    text: "\u042D\u0442\u043E \u0442\u0432\u043E\u044F \u043D\u043E\u0432\u0430\u044F
      \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u043E\u0441\u0442\u044C. \u041F\u043E
      \u0445\u043E\u0434\u0443 \u0434\u0435\u043B\u0430 \u0440\u0430\u0437\u0431\u0435\u0440\u0435\u0448\u044C\u0441\u044F,
      \u043D\u0435 \u043F\u0435\u0440\u0435\u0436\u0438\u0432\u0430\u0439. \u0422\u0430\u043A,
      \u043D\u0443 \u0432\u0440\u043E\u0434\u0435 \u0432\u0441\u0435 \u0440\u0430\u0441\u0441\u043A\u0430\u0437\u0430\u043B.
      \u0422\u0435\u043F\u0435\u0440\u044C \u0442\u044B \u043C\u043E\u0436\u0435\u0448\u044C
      \u043E\u0442\u043F\u0440\u0430\u0432\u043B\u044F\u0442\u044C\u0441\u044F \u0432\u043E\u043D
      \u0432 \u0442\u0443 \u0434\u0432\u0435\u0440\u044C."
    background: {fileID: 21300000, guid: 41bff0e74cdc3af49a90b77ae5be31da, type: 3}
    leftPortrait: {fileID: 21300000, guid: dfde3493724dca44f8907cfe2bde76f9, type: 3}
    rightPortrait: {fileID: 21300000, guid: 9887c52db6846274593998508bd203de, type: 3}
    leftActive: 0
    rightActive: 1
    useFade: 0
    fadeDuration: 0.35
    shakeCamera: 0
    shakeDuration: 0.2
    shakeStrength: 8
    delayBeforeShow: 0
    actions: []
  - speaker: 1
    speakerName: "\u0427\u0435\u0440\u043D\u044B\u0439 \u0431\u043E\u0433"
    text: "\u0423\u0434\u0430\u0447\u0438, \u0447\u0435\u043B\u043E\u0432\u0435\u043A.
      \u041D\u0435 \u0437\u0430\u0431\u0443\u0434\u044C \u0441\u043E\u0431\u0438\u0440\u0430\u0442\u044C
      \u043E\u0441\u043A\u043E\u043B\u043A\u0438."
    background: {fileID: 21300000, guid: 41bff0e74cdc3af49a90b77ae5be31da, type: 3}
    leftPortrait: {fileID: 21300000, guid: de1888ef3f4bcb74b992e31a97a02005, type: 3}
    rightPortrait: {fileID: 21300000, guid: 9887c52db6846274593998508bd203de, type: 3}
    leftActive: 1
    rightActive: 0
    useFade: 0
    fadeDuration: 0.35
    shakeCamera: 0
    shakeDuration: 0.2
    shakeStrength: 8
    delayBeforeShow: 0
    actions: []
  - speaker: 3
    speakerName: "\u0413\u0413"
    text: "\u0421\u043F\u0430\u0441\u0438\u0431\u043E, \u043D\u0430\u0432\u0435\u0440\u043D\u043E?"
    background: {fileID: 21300000, guid: 41bff0e74cdc3af49a90b77ae5be31da, type: 3}
    leftPortrait: {fileID: 21300000, guid: ff6420a111dc95447b5622944798ab86, type: 3}
    rightPortrait: {fileID: 21300000, guid: 9887c52db6846274593998508bd203de, type: 3}
    leftActive: 1
    rightActive: 0
    useFade: 0
    fadeDuration: 0.35
    shakeCamera: 0
    shakeDuration: 0.2
    shakeStrength: 8
    delayBeforeShow: 0
    actions: []
  - speaker: 2
    speakerName: "\u0411\u0435\u043B\u044B\u0439 \u0431\u043E\u0433"
    text: "\u041E\u0439, \u0447\u0443\u0442\u044C \u043D\u0435 \u0437\u0430\u0431\u044B\u043B,
      \u0435\u0441\u043B\u0438 \u0447\u0442\u043E-\u0442\u043E \u043F\u043E\u0439\u0434\u0435\u0442
      \u043D\u0435 \u0442\u0430\u043A \u0438 \u0442\u044B \u0443\u043C\u0440\u0435\u0448\u044C
      \u2014 \u043D\u0435 \u043F\u0435\u0440\u0435\u0436\u0438\u0432\u0430\u0439.
      \u0422\u0435\u0431\u044F \u0434\u043E\u043B\u0436\u043D\u043E \u0432\u0435\u0440\u043D\u0443\u0442\u044C
      \u043D\u0430\u0437\u0430\u0434 \u043A \u043D\u0430\u043C, \u0438 \u0442\u044B
      \u0441\u043D\u043E\u0432\u0430 \u0441\u043C\u043E\u0436\u0435\u0448\u044C \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0438\u0442\u044C
      \u0431\u043E\u0440\u044C\u0431\u0443."
    background: {fileID: 21300000, guid: 41bff0e74cdc3af49a90b77ae5be31da, type: 3}
    leftPortrait: {fileID: 21300000, guid: ff6420a111dc95447b5622944798ab86, type: 3}
    rightPortrait: {fileID: 21300000, guid: 9887c52db6846274593998508bd203de, type: 3}
    leftActive: 0
    rightActive: 1
    useFade: 0
    fadeDuration: 0.35
    shakeCamera: 0
    shakeDuration: 0.2
    shakeStrength: 8
    delayBeforeShow: 0
    actions: []
  - speaker: 3
    speakerName: "\u0413\u0413"
    text: "\u041D\u0435 \u043F\u043E\u043D\u0438\u043C\u0430\u044E, \u043C\u043D\u0435
      \u0440\u0430\u0434\u043E\u0432\u0430\u0442\u044C\u0441\u044F, \u0447\u0442\u043E
      \u044F \u0432\u043E\u0441\u043A\u0440\u0435\u0441\u043D\u0443 \u0432 \u0441\u043B\u0443\u0447\u0430\u0435
      \u0447\u0435\u0433\u043E, \u0438\u043B\u0438 \u0431\u043E\u044F\u0442\u044C\u0441\u044F,
      \u0447\u0442\u043E \u044F \u0432\u043E\u043E\u0431\u0449\u0435 \u043C\u043E\u0433\u0443
      \u0443\u043C\u0438\u0440\u0430\u0442\u044C \u043C\u043D\u043E\u0433\u043E \u0440\u0430\u0437?"
    background: {fileID: 21300000, guid: 41bff0e74cdc3af49a90b77ae5be31da, type: 3}
    leftPortrait: {fileID: 21300000, guid: 8b1f0512e6f36324b895a8282b576de0, type: 3}
    rightPortrait: {fileID: 21300000, guid: 9887c52db6846274593998508bd203de, type: 3}
    leftActive: 1
    rightActive: 0
    useFade: 0
    fadeDuration: 0.35
    shakeCamera: 0
    shakeDuration: 0.2
    shakeStrength: 8
    delayBeforeShow: 0
    actions: []
  - speaker: 1
    speakerName: "\u0427\u0435\u0440\u043D\u044B\u0439 \u0431\u043E\u0433"
    text: "\u041D\u0435 \u043D\u0430\u0434\u043E \u043D\u0438\u0447\u0435\u0433\u043E
      \u0431\u043E\u044F\u0442\u044C\u0441\u044F, \u043F\u0440\u043E\u0441\u0442\u043E
      \u0438\u0434\u0438 \u0443\u0436\u0435."
    background: {fileID: 21300000, guid: 41bff0e74cdc3af49a90b77ae5be31da, type: 3}
    leftPortrait: {fileID: 21300000, guid: de1888ef3f4bcb74b992e31a97a02005, type: 3}
    rightPortrait: {fileID: 21300000, guid: 9887c52db6846274593998508bd203de, type: 3}
    leftActive: 1
    rightActive: 0
    useFade: 0
    fadeDuration: 0.35
    shakeCamera: 0
    shakeDuration: 0.2
    shakeStrength: 8
    delayBeforeShow: 0
    actions: []
  - speaker: 1
    speakerName: "\u0427\u0435\u0440\u043D\u044B\u0439 \u0431\u043E\u0433"
    text: "\u0422\u044B \u0435\u043C\u0443 \u0441\u043A\u0430\u0437\u0430\u043B,
      \u0441\u043A\u043E\u043B\u044C\u043A\u043E \u043E\u0441\u043A\u043E\u043B\u043A\u043E\u0432
      \u043E\u043D \u0434\u043E\u043B\u0436\u0435\u043D \u043D\u0430\u0439\u0442\u0438?"
    background: {fileID: 21300000, guid: 41bff0e74cdc3af49a90b77ae5be31da, type: 3}
    leftPortrait: {fileID: 21300000, guid: de1888ef3f4bcb74b992e31a97a02005, type: 3}
    rightPortrait: {fileID: 21300000, guid: 9887c52db6846274593998508bd203de, type: 3}
    leftActive: 1
    rightActive: 0
    useFade: 0
    fadeDuration: 0.35
    shakeCamera: 0
    shakeDuration: 0.2
    shakeStrength: 8
    delayBeforeShow: 0
    actions: []
  - speaker: 2
    speakerName: "\u0411\u0435\u043B\u044B\u0439 \u0431\u043E\u0433"
    text: "\u041D\u0435\u0442, \u043D\u043E \u044D\u0442\u043E \u0438 \u043D\u0435
      \u043D\u0430\u0434\u043E. \u041E\u043D \u0432\u0441\u0435 \u0440\u0430\u0432\u043D\u043E
      \u0437\u0430 \u0440\u0430\u0437 \u043D\u0435 \u0441\u043E\u0431\u0435\u0440\u0435\u0442."
    background: {fileID: 21300000, guid: 41bff0e74cdc3af49a90b77ae5be31da, type: 3}
    leftPortrait: {fileID: 21300000, guid: de1888ef3f4bcb74b992e31a97a02005, type: 3}
    rightPortrait: {fileID: 21300000, guid: 9887c52db6846274593998508bd203de, type: 3}
    leftActive: 0
    rightActive: 1
    useFade: 0
    fadeDuration: 0.35
    shakeCamera: 0
    shakeDuration: 0.2
    shakeStrength: 8
    delayBeforeShow: 0
    actions: []
  - speaker: 1
    speakerName: "\u0427\u0435\u0440\u043D\u044B\u0439 \u0431\u043E\u0433"
    text: "\u0425\u0430\u0445\u0430, \u043D\u0443 \u0442\u0443\u0442 \u0442\u044B
      \u043F\u0440\u0430\u0432. \u041B\u0430\u0434\u043D\u043E, \u0430 \u0442\u0435\u043F\u0435\u0440\u044C
      \u0441\u043A\u0430\u0436\u0438 \u0447\u0435\u0441\u0442\u043D\u043E, \u0437\u0430\u0447\u0435\u043C
      \u043C\u0430\u043B\u043E\u0433\u043E \u043E\u0442\u043F\u0440\u0430\u0432\u0438\u043B
      \u043D\u0430 \u044D\u0442\u0443 \u043A\u0430\u0442\u043E\u0440\u0433\u0443?"
    background: {fileID: 21300000, guid: 41bff0e74cdc3af49a90b77ae5be31da, type: 3}
    leftPortrait: {fileID: 21300000, guid: de1888ef3f4bcb74b992e31a97a02005, type: 3}
    rightPortrait: {fileID: 21300000, guid: 9887c52db6846274593998508bd203de, type: 3}
    leftActive: 1
    rightActive: 0
    useFade: 0
    fadeDuration: 0.35
    shakeCamera: 0
    shakeDuration: 0.2
    shakeStrength: 8
    delayBeforeShow: 0
    actions: []
  - speaker: 2
    speakerName: "\u0411\u0435\u043B\u044B\u0439 \u0431\u043E\u0433"
    text: "\u0421\u0435\u0433\u043E\u0434\u043D\u044F \u0434\u043E\u043B\u0436\u0435\u043D
      \u043F\u0440\u043E\u0439\u0442\u0438 \u0437\u0432\u0435\u0437\u0434\u043D\u044B\u0439
      \u0441\u0442\u0440\u0438\u043C \u0441 \u043C\u043E\u0435\u0439 \u043B\u044E\u0431\u0438\u043C\u043E\u0439
      \u0430\u0439\u0434\u043E\u043B\u043A\u043E\u0439 \u0438\u0437 \u0441\u043E\u0441\u0435\u0434\u043D\u0435\u0439
      \u0433\u0430\u043B\u0430\u043A\u0442\u0438\u043A\u0438! \u041D\u0435 \u043C\u043E\u0433\u0443
      \u043F\u0440\u043E\u043F\u0443\u0441\u0442\u0438\u0442\u044C."
    background: {fileID: 21300000, guid: 41bff0e74cdc3af49a90b77ae5be31da, type: 3}
    leftPortrait: {fileID: 21300000, guid: de1888ef3f4bcb74b992e31a97a02005, type: 3}
    rightPortrait: {fileID: 21300000, guid: 9887c52db6846274593998508bd203de, type: 3}
    leftActive: 0
    rightActive: 1
    useFade: 0
    fadeDuration: 0.35
    shakeCamera: 0
    shakeDuration: 0.2
    shakeStrength: 8
    delayBeforeShow: 0
    actions: []
  - speaker: 1
    speakerName: "\u0427\u0435\u0440\u043D\u044B\u0439 \u0431\u043E\u0433"
    text: "\u0427\u0435\u043B, \u0442\u044B\u2026"
    background: {fileID: 21300000, guid: 41bff0e74cdc3af49a90b77ae5be31da, type: 3}
    leftPortrait: {fileID: 21300000, guid: 2ec1f9d991978b14aaa1555dfc0087d7, type: 3}
    rightPortrait: {fileID: 21300000, guid: 9887c52db6846274593998508bd203de, type: 3}
    leftActive: 1
    rightActive: 0
    useFade: 0
    fadeDuration: 0.35
    shakeCamera: 0
    shakeDuration: 0.2
    shakeStrength: 8
    delayBeforeShow: 0
    actions: []
  - speaker: 2
    speakerName: "\u0411\u0435\u043B\u044B\u0439 \u0431\u043E\u0433"
    text: "\u041E\u0439, \u043A\u0442\u043E \u0431\u044B \u0433\u043E\u0432\u043E\u0440\u0438\u043B.
      \u0422\u044B \u0436\u0435 \u0441\u0430\u043C \u043D\u0430\u0445\u0430\u043B\u0442\u0443\u0440\u0438\u043B
      \u0441 \u0437\u0430\u0449\u0438\u0442\u043E\u0439 \u044D\u0442\u043E\u0433\u043E
      \u043C\u0438\u0440\u0430, \u0438 \u0442\u0435\u043F\u0435\u0440\u044C \u043E\u0431\u0432\u0438\u043D\u044F\u0435\u0448\u044C
      \u043C\u0435\u043D\u044F, \u0447\u0442\u043E \u044F \u0437\u0430 \u0442\u043E\u0431\u043E\u0439
      \u043D\u0435 \u043F\u043E\u0434\u0442\u0435\u0440? \u0418 \u043F\u043E\u0447\u0435\u043C\u0443
      \u044F \u0432\u043E\u043E\u0431\u0449\u0435 \u0434\u043E\u043B\u0436\u0435\u043D
      \u0440\u0443\u0447\u043A\u0430\u043C\u0438 \u0432\u0441\u0435 \u0444\u0438\u043A\u0441\u0438\u0442\u044C?
      \u041D\u0435\u0442 \u0443\u0436, \u044F \u0437\u0430 \u0430\u0432\u0442\u043E\u043C\u0430\u0442\u0438\u0437\u0430\u0446\u0438\u044E
      \u043F\u0440\u043E\u0446\u0435\u0441\u0441\u043E\u0432! \u0421\u043A\u0430\u0436\u0438
      \u0441\u043F\u0430\u0441\u0438\u0431\u043E, \u0447\u0442\u043E \u044F \u0432\u043E\u043E\u0431\u0449\u0435
      \u0432\u0437\u044F\u043B\u0441\u044F \u0437\u0430 \u044D\u0442\u043E."
    background: {fileID: 21300000, guid: 41bff0e74cdc3af49a90b77ae5be31da, type: 3}
    leftPortrait: {fileID: 21300000, guid: de1888ef3f4bcb74b992e31a97a02005, type: 3}
    rightPortrait: {fileID: 21300000, guid: 9887c52db6846274593998508bd203de, type: 3}
    leftActive: 0
    rightActive: 1
    useFade: 0
    fadeDuration: 0.35
    shakeCamera: 0
    shakeDuration: 0.2
    shakeStrength: 8
    delayBeforeShow: 0
    actions: []
  - speaker: 1
    speakerName: "\u0427\u0435\u0440\u043D\u044B\u0439 \u0431\u043E\u0433"
    text: "\u041B\u0430\u0434\u043D\u043E, \u043F\u043E\u043D\u044F\u043B \u0442\u0435\u0431\u044F,
      \u0440\u043E\u0434\u043D\u043E\u0439. \u0418\u0434\u0438 \u0441\u043C\u043E\u0442\u0440\u0438
      \u0443\u0436\u0435 \u0441\u0432\u043E\u0439 \u0441\u0442\u0440\u0438\u043C."
    background: {fileID: 21300000, guid: 41bff0e74cdc3af49a90b77ae5be31da, type: 3}
