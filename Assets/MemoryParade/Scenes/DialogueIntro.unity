    shakeDuration: 0.2
    shakeStrength: 8
    delayBeforeShow: 0
    actions: []
  - speaker: 2
    speakerName: "\u0411\u0435\u043B\u044B\u0439 \u0431\u043E\u0433"
    text: "\u0418 \u0442\u0435\u0431\u0435 \u0437\u0434\u0440\u0430\u0432\u0441\u0442\u0432\u0443\u0439,
      \u0447\u0435\u043B\u043E\u0432\u0435\u043A. \u0410 \u0442\u044B \u0441\u0430\u043C-\u0442\u043E?
      \u0412\u0435\u0441\u044C \u043A\u0430\u043A\u043E\u0439-\u0442\u043E\u2026
      \u0441\u0442\u0440\u0435\u043C\u043D\u044B\u0439? \u0425\u043E\u0442\u044F,
      \u0432 \u043F\u0440\u0438\u043D\u0446\u0438\u043F\u0435, \u043C\u043D\u0435
      \u0442\u0430\u043A\u043E\u0439 \u0438 \u043D\u0443\u0436\u0435\u043D. \u0422\u0435\u0431\u044F
      \u0438\u0441\u043A\u0430\u0442\u044C \u043D\u0438\u043A\u0442\u043E \u043D\u0435
      \u0431\u0443\u0434\u0435\u0442. \u0422\u044B \u0438\u0434\u0435\u0448\u044C
      \u0441\u043E \u043C\u043D\u043E\u0439, \u0441\u0435\u0440\u044B\u0439."
    background: {fileID: 21300000, guid: a3855bffefdd9b7429ba417d560d6369, type: 3}
    leftPortrait: {fileID: 21300000, guid: 8b1f0512e6f36324b895a8282b576de0, type: 3}
    rightPortrait: {fileID: 21300000, guid: 9887c52db6846274593998508bd203de, type: 3}
