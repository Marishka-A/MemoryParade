    actions: []
  - speaker: 2
    speakerName: "\u0411\u0435\u043B\u044B\u0439 \u0431\u043E\u0433"
    text: "\u0410, \u0442\u043E\u0447\u043D\u043E, \u0434\u044B\u0440\u044F\u0432\u0430\u044F
      \u043C\u043E\u044F \u0433\u043E\u043B\u043E\u0432\u0430! \u042F \u0441\u043E\u0432\u0441\u0435\u043C
      \u0437\u0430\u0431\u044B\u043B, \u0447\u0442\u043E \u0432\u044B, \u043B\u044E\u0434\u0438,
      \u0435\u0449\u0435 \u043D\u0435 \u0440\u0430\u0437\u0432\u0438\u043B\u0438\u0441\u044C
      \u0434\u043E \u0442\u0430\u043A\u043E\u0439 \u0441\u0442\u0435\u043F\u0435\u043D\u0438.
      \u041F\u0440\u043E\u0441\u0442\u0438, \u043C\u043E\u0439 \u043F\u0440\u043E\u043C\u0430\u0445.
      \u0414\u0430\u0432\u0430\u0439 \u0432\u0435\u0440\u043D\u0435\u043C\u0441\u044F
      \u043A \u043D\u0430\u0448\u0438\u043C \u0431\u0430\u0440\u0430\u043D\u0430\u043C,
      \u0430 \u0442\u043E\u0447\u043D\u0435\u0435 \u043A \u0442\u0435\u043C \u043C\u0435\u0440\u0437\u043E\u0441\u0442\u044F\u043C,
      \u0447\u0442\u043E \u0443\u0436\u0435 \u0436\u0434\u0443\u0442 \u043D\u0435
      \u0434\u043E\u0436\u0434\u0443\u0442\u0441\u044F \u043E\u0442\u0432\u0435\u0434\u0430\u0442\u044C
      \u0442\u0432\u043E\u0435\u0439 \u0431\u043E\u0433\u0430\u0442\u044B\u0440\u0441\u043A\u043E\u0439
      \u0441\u0438\u043B\u0443\u0448\u043A\u0438. \u0421\u0435\u0439\u0447\u0430\u0441
      \u044F \u0434\u0430\u043C \u0442\u0435\u0431\u0435 \u0441\u0432\u043E\u0439
      \u043C\u0435\u0447 \u0438 \u043A\u043E\u0435-\u0447\u0442\u043E \u0435\u0449\u0435,
      \u0447\u0442\u043E \u0442\u0435\u0431\u0435 \u043D\u0430\u0434\u043E \u0431\u0443\u0434\u0435\u0442
      \u043F\u0440\u043E\u0433\u043B\u043E\u0442\u0438\u0442\u044C."
    background: {fileID: 21300000, guid: 41bff0e74cdc3af49a90b77ae5be31da, type: 3}
