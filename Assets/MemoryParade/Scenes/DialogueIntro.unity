    actions: []
  - speaker: 2
    speakerName: "\u0411\u0435\u043B\u044B\u0439 \u0431\u043E\u0433"
    text: "\u0423\u0445, \u0432 \u044D\u0442\u043E\u0442 \u0440\u0430\u0437 \u0442\u0440\u0435\u0449\u0438\u043D\u0430
      \u043A\u0430\u043A\u0430\u044F-\u0442\u043E \u0441\u0442\u0440\u0430\u043D\u043D\u0430\u044F.
      \u0427\u0435\u0440\u0442, \u043F\u0440\u0438\u0434\u0435\u0442\u0441\u044F
      \u043B\u0435\u0437\u0442\u044C \u0442\u0443\u0434\u0430 \u0433\u043B\u0430\u0437\u043E\u043C,
      \u0447\u0442\u043E\u0431\u044B \u043F\u0440\u043E\u0432\u0435\u0440\u0438\u0442\u044C."
    background: {fileID: 21300000, guid: 70dce2e49f02e1045bfde99caae32c01, type: 3}
