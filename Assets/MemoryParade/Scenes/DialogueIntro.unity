  - speaker: 1
    speakerName: "\u0427\u0435\u0440\u043D\u044B\u0439 \u0431\u043E\u0433"
    text: "\u0410? \u041E\u2026 \u043E \u043D\u0435\u0442! \u041F\u043E\u0445\u043E\u0436\u0435,
      \u0447\u0442\u043E-\u0442\u043E \u0441\u043B\u0443\u0447\u0438\u043B\u043E\u0441\u044C
      \u0441 \u043A\u0443\u043F\u043E\u043B\u043E\u043C! \u042D\u0439, \u0434\u0440\u0443\u0436\u0438\u0449\u0435,
      \u0441\u0445\u043E\u0434\u0438 \u043F\u0440\u043E\u0432\u0435\u0440\u044C \u0447\u0442\u043E
      \u0442\u0430\u043C."
    background: {fileID: 21300000, guid: 41bff0e74cdc3af49a90b77ae5be31da, type: 3}
    leftPortrait: {fileID: 21300000, guid: de1888ef3f4bcb74b992e31a97a02005, type: 3}
    rightPortrait: {fileID: 21300000, guid: 9887c52db6846274593998508bd203de, type: 3}
    leftActive: 1
    rightActive: 0
    useFade: 0
    fadeDuration: 0.35
    shakeCamera: 0
    shakeDuration: 0.2
    shakeStrength: 8
    delayBeforeShow: 0
    actions: []
  - speaker: 2
    speakerName: "\u0411\u0435\u043B\u044B\u0439 \u0431\u043E\u0433"
    text: "\u041F\u043E\u0447\u0435\u043C\u0443\u2026 \u043D\u0443 \u043F\u043E\u0447\u0435\u043C\u0443
      \u0441\u043D\u043E\u0432\u0430 \u044F? \u0412 \u043F\u0440\u043E\u0448\u043B\u044B\u0439,
      \u0438 \u0434\u0430\u0436\u0435 \u043F\u043E\u0437\u0430\u043F\u0440\u043E\u0448\u043B\u044B\u0439
      \u0440\u0430\u0437 \u0445\u043E\u0434\u0438\u043B \u044F, \u0438 \u0432\u043E\u043E\u0431\u0449\u0435
      \u0432\u0441\u0435\u0433\u0434\u0430, \u0441\u043A\u043E\u043B\u044C\u043A\u043E
      \u0441\u0435\u0431\u044F \u043F\u043E\u043C\u043D\u044E. \u0422\u0435\u0431\u0435
      \u0441\u043E\u0432\u0441\u0435\u043C \u043D\u0435 \u0441\u0442\u044B\u0434\u043D\u043E?"
    background: {fileID: 21300000, guid: 41bff0e74cdc3af49a90b77ae5be31da, type: 3}
    leftPortrait: {fileID: 21300000, guid: de1888ef3f4bcb74b992e31a97a02005, type: 3}
    rightPortrait: {fileID: 21300000, guid: 9887c52db6846274593998508bd203de, type: 3}
    leftActive: 0
    rightActive: 1
    useFade: 0
    fadeDuration: 0.35
    shakeCamera: 0
    shakeDuration: 0.2
    shakeStrength: 8
    delayBeforeShow: 0
    actions: []
  - speaker: 1
    speakerName: "\u0427\u0435\u0440\u043D\u044B\u0439 \u0431\u043E\u0433"
    text: "\u041D\u0443 \u044F \u0436\u0435 \u043D\u0435 \u0432\u0438\u043D\u043E\u0432\u0430\u0442,
      \u0447\u0442\u043E \u043D\u0435 \u043C\u043E\u0433\u0443 \u0445\u043E\u0434\u0438\u0442\u044C!
      \u0422\u044B \u043F\u043E\u0441\u043C\u043E\u0442\u0440\u0438 \u043D\u0430
      \u043C\u0435\u043D\u044F, \u0443 \u043C\u0435\u043D\u044F \u0442\u043E\u043B\u044C\u043A\u043E
      \u043A\u043E\u0440\u043D\u0438! \u042F \u0431\u0435\u0434\u043D\u0435\u043D\u044C\u043A\u0438\u0439
      \u0431\u0435\u0437\u043D\u043E\u0433\u0438\u0439 \u0438\u043D\u0432\u0430\u043B\u0438\u0434!"
    background: {fileID: 21300000, guid: 41bff0e74cdc3af49a90b77ae5be31da, type: 3}
    leftPortrait: {fileID: 21300000, guid: de1888ef3f4bcb74b992e31a97a02005, type: 3}
    rightPortrait: {fileID: 21300000, guid: 9887c52db6846274593998508bd203de, type: 3}
    leftActive: 1
    rightActive: 0
    useFade: 0
    fadeDuration: 0.35
    shakeCamera: 0
    shakeDuration: 0.2
    shakeStrength: 8
    delayBeforeShow: 0
    actions: []
  - speaker: 2
    speakerName: "\u0411\u0435\u043B\u044B\u0439 \u0431\u043E\u0433"
    text: "\u042F \u0442\u0432\u043E\u044E \u043B\u0435\u043D\u044C \u0442\u0435\u0440\u043F\u0435\u0442\u044C
      \u043D\u0435 \u043D\u0430\u043C\u0435\u0440\u0435\u043D! \u0415\u0441\u043B\u0438
      \u0431\u044B \u0445\u043E\u0442\u0435\u043B - \u0434\u0430\u0432\u043D\u043E
      \u0431\u044B \u0432\u044B\u0434\u0440\u0430\u043B \u043A\u043E\u0440\u043D\u0438
      \u0438 \u043F\u043E\u0448\u0435\u043B. \u0410 \u0442\u0430\u043A \u0442\u044B
      \u043F\u0440\u043E\u0441\u0442\u043E \u0445\u0438\u0442\u0440\u044B\u0439 \u0434\u0440\u044F\u0445\u043B\u044B\u0439
      \u043F\u0435\u043D\u044C, \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043F\u043E\u043B\u044C\u0437\u0443\u0435\u0442\u0441\u044F
      \u043C\u043E\u0435\u0439 \u0434\u043E\u0431\u0440\u043E\u0442\u043E\u0439. "
    background: {fileID: 21300000, guid: 41bff0e74cdc3af49a90b77ae5be31da, type: 3}
    leftPortrait: {fileID: 21300000, guid: de1888ef3f4bcb74b992e31a97a02005, type: 3}
    rightPortrait: {fileID: 21300000, guid: cb9a13413bbda0243964fc4401a2e9ab, type: 3}
    leftActive: 0
    rightActive: 1
    useFade: 0
    fadeDuration: 0.35
    shakeCamera: 0
    shakeDuration: 0.2
    shakeStrength: 8
    delayBeforeShow: 0
    actions: []
  - speaker: 1
    speakerName: "\u0427\u0435\u0440\u043D\u044B\u0439 \u0431\u043E\u0433"
    text: "\u041D\u0443 \u043F\u0440\u043E\u0441\u0442\u0438-\u043F\u0440\u043E\u0441\u0442\u0438!
      \u0414\u0430\u0432\u0430\u0439 \u044D\u0442\u043E \u0431\u0443\u0434\u0435\u0442
      \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0439 \u0440\u0430\u0437\u043E\u0447\u0435\u043A!
      \u0418 \u043F\u043E\u0442\u043E\u043C \u044F \u0432\u043E\u0437\u044C\u043C\u0443
      \u0441\u0435\u0431\u044F \u0432 \u0440\u0443\u043A\u0438, \u043E\u0439, \u0442\u043E
      \u0435\u0441\u0442\u044C \u0432 \u0432\u0435\u0442\u043A\u0438, \u0438 \u043F\u043E\u0439\u0434\u0443!"
    background: {fileID: 21300000, guid: 41bff0e74cdc3af49a90b77ae5be31da, type: 3}
    leftPortrait: {fileID: 21300000, guid: 6a8fb94334ea19347b17c964a568cc25, type: 3}
    rightPortrait: {fileID: 21300000, guid: cb9a13413bbda0243964fc4401a2e9ab, type: 3}
    leftActive: 1
    rightActive: 0
    useFade: 0
    fadeDuration: 0.35
    shakeCamera: 0
    shakeDuration: 0.2
    shakeStrength: 8
    delayBeforeShow: 0
    actions: []
  - speaker: 2
    speakerName: "\u0411\u0435\u043B\u044B\u0439 \u0431\u043E\u0433"
    text: "\u041C\u043C, \u043B\u0430\u0434\u043D\u043E \u0442\u0440\u0443\u0445\u043B\u044F\u0432\u044B\u0439,
      \u0434\u043E\u0433\u043E\u0432\u043E\u0440\u0438\u043B\u0438\u0441\u044C. \u041F\u043E\u0439\u0434\u0443
      \u043F\u0440\u043E\u0432\u0435\u0440\u044E, \u043D\u043E \u044D\u0442\u043E
      \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u043E
      \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0439 \u0440\u0430\u0437. "
    background: {fileID: 21300000, guid: 41bff0e74cdc3af49a90b77ae5be31da, type: 3}
    leftPortrait: {fileID: 21300000, guid: 6a8fb94334ea19347b17c964a568cc25, type: 3}
    rightPortrait: {fileID: 21300000, guid: 9887c52db6846274593998508bd203de, type: 3}
    leftActive: 0
    rightActive: 1
    useFade: 0
