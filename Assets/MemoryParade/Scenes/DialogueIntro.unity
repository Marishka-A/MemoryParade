    text: "*\u0412\u043E\u0442 \u0431\u044B \u043F\u043E\u0441\u043A\u043E\u0440\u0435\u0435
      \u043D\u0430\u0441\u0442\u0443\u043F\u0438\u043B \u0432\u0435\u0447\u0435\u0440!
      \u0416\u0434\u0443 \u043D\u0435 \u0434\u043E\u0436\u0434\u0443\u0441\u044C
      \u043A\u043E\u0433\u0434\u0430\u2026*"
