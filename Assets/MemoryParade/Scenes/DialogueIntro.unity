  - speaker: 2
    speakerName: "\u0411\u0435\u043B\u044B\u0439 \u0431\u043E\u0433"
    text: "\u0418\u0442\u0430\u043A, \u0442\u0435\u0431\u0435 \u0432\u044B\u043F\u0430\u043B\u0430
      \u0432\u0435\u043B\u0438\u043A\u0430\u044F \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E\u0441\u0442\u044C
      \u0441\u043F\u0430\u0441\u0442\u0438 \u044D\u0442\u043E\u0442 \u043C\u0438\u0440
      \u043E\u0442 \u0442\u043E\u0442\u0430\u043B\u044C\u043D\u043E\u0433\u043E \u0440\u0430\u0437\u0440\u0443\u0448\u0435\u043D\u0438\u044F!
      \u0421\u0435\u0439\u0447\u0430\u0441 \u043A\u0443\u043F\u043E\u043B, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
      \u0432\u0438\u0441\u0435\u043B \u043D\u0430\u0434 \u043D\u0430\u0448\u0438\u043C
      \u043C\u0438\u0440\u043E\u043C, \u043F\u0440\u043E\u0431\u0438\u0442 \u0438
      \u0440\u0430\u0437\u043B\u0435\u0442\u0435\u043B\u0441\u044F \u0432\u043C\u0435\u0441\u0442\u0435
      \u0441 \u043D\u043E\u0432\u043E\u043F\u0440\u0438\u0431\u044B\u0432\u0448\u0438\u043C\u0438
      \u0433\u043E\u0441\u0442\u044F\u043C\u0438. \u0422\u0435\u0431\u0435 \u043D\u0430\u0434\u043E
      \u0443\u0431\u0438\u0442\u044C \u0441\u043A\u043B\u0438\u0437\u043A\u0438\u0445
      \u0433\u0430\u0434\u043E\u0432 \u0438 \u043E\u0442\u043E\u0431\u0440\u0430\u0442\u044C
      \u0443 \u043D\u0438\u0445 \u043E\u0441\u043A\u043E\u043B\u043A\u0438. \u041F\u043E\u0447\u0435\u043C\u0443
      \u0442\u044B? \u0414\u0430 \u0432\u0441\u0435 \u043F\u043E\u0442\u043E\u043C\u0443,
      \u0447\u0442\u043E \u0442\u0435 \u043C\u0435\u0440\u0437\u043A\u0438\u0435
      \u0443\u0431\u043B\u044E\u0434\u043A\u0438, \u043F\u0440\u043E\u043D\u0438\u043A\u0448\u0438\u0435
      \u0432 \u043D\u0430\u0448 \u043C\u0438\u0440, \u043C\u043E\u0433\u0443\u0442
      \u0431\u044B\u0442\u044C \u0430\u0442\u0430\u043A\u043E\u0432\u0430\u043D\u044B
      \u0442\u043E\u043B\u044C\u043A\u043E \u0441 \u0431\u043B\u0438\u0437\u043A\u043E\u0433\u043E
      \u0440\u0430\u0441\u0441\u0442\u043E\u044F\u043D\u0438\u044F."
    background: {fileID: 21300000, guid: 41bff0e74cdc3af49a90b77ae5be31da, type: 3}
    leftPortrait: {fileID: 21300000, guid: 8b1f0512e6f36324b895a8282b576de0, type: 3}
    rightPortrait: {fileID: 21300000, guid: cb9a13413bbda0243964fc4401a2e9ab, type: 3}
    leftActive: 0
    rightActive: 1
    useFade: 0
    fadeDuration: 0.35
    shakeCamera: 0
    shakeDuration: 0.2
    shakeStrength: 8
    delayBeforeShow: 0
    actions: []
  - speaker: 3
    speakerName: "\u0413\u0413"
    text: "\u0410 \u043F\u043E\u0447\u0435\u043C\u0443 \u0442\u043E\u0433\u0434\u0430
      \u0432\u044B \u043D\u0435 \u043C\u043E\u0436\u0435\u0442\u0435 \u043F\u0440\u043E\u0441\u0442\u043E
      \u0432\u0437\u044F\u0442\u044C \u0438 \u0443\u0434\u0430\u0440\u0438\u0442\u044C
      \u0438\u0445, \u043A\u0430\u043A \u0441\u0434\u0435\u043B\u0430\u043B\u0438
      \u044D\u0442\u043E \u0441\u043E \u043C\u043D\u043E\u0439 \u043F\u0430\u0440\u0443
      \u043C\u0438\u043D\u0443\u0442 \u043D\u0430\u0437\u0430\u0434?"
    background: {fileID: 21300000, guid: 41bff0e74cdc3af49a90b77ae5be31da, type: 3}
    leftPortrait: {fileID: 21300000, guid: dfde3493724dca44f8907cfe2bde76f9, type: 3}
    rightPortrait: {fileID: 21300000, guid: cb9a13413bbda0243964fc4401a2e9ab, type: 3}
    leftActive: 1
    rightActive: 0
    useFade: 0
    fadeDuration: 0.35
    shakeCamera: 0
    shakeDuration: 0.2
    shakeStrength: 8
    delayBeforeShow: 0
    actions: []
  - speaker: 2
    speakerName: "\u0411\u0435\u043B\u044B\u0439 \u0431\u043E\u0433"
    text: "\u0410 \u0442\u044B \u0443\u043C\u0435\u043D! \u041D\u043E \u043D\u0435\u0442,
      \u0432\u0441\u0435 \u043D\u0435 \u0442\u0430\u043A \u043F\u0440\u043E\u0441\u0442\u043E,
      \u043A\u0430\u043A \u0442\u044B \u0434\u0443\u043C\u0430\u0435\u0448\u044C.
      \u041F\u0440\u043E\u0441\u0442\u043E \u043F\u043E\u043D\u0438\u043C\u0430\u0435\u0448\u044C\u2026
      \u043D\u0438 \u044F, \u043D\u0438 \u043C\u043E\u0439 \u0434\u0440\u0443\u0433,
      \u0443\u0432\u044B, \u043D\u0435 \u043F\u043E\u0434\u0445\u043E\u0434\u0438\u043C
      \u0434\u043B\u044F \u0430\u0442\u0430\u043A \u0431\u043B\u0438\u0436\u043D\u0435\u0433\u043E
      \u0431\u043E\u044F. \u0418 \u0441\u0435\u0439\u0447\u0430\u0441 \u043D\u0430\u043C
      \u043D\u0443\u0436\u0435\u043D \u043A\u043E\u0437\u0435\u043B \u043E\u0442\u043F\u0443\u0449\u0435\u043D\u0438\u044F,
      \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0441\u043C\u043E\u0436\u0435\u0442
      \u0438\u0445 \u0432\u0441\u0435\u0445 \u0438\u0441\u0442\u0440\u0435\u0431\u0438\u0442\u044C.
      \u0418\u0433\u0440\u0430\u043B \u043A\u043E\u0433\u0434\u0430-\u043D\u0438\u0431\u0443\u0434\u044C
      \u0432 RPG?"
    background: {fileID: 21300000, guid: 41bff0e74cdc3af49a90b77ae5be31da, type: 3}
    leftPortrait: {fileID: 21300000, guid: dfde3493724dca44f8907cfe2bde76f9, type: 3}
    rightPortrait: {fileID: 21300000, guid: 9887c52db6846274593998508bd203de, type: 3}
