    delayBeforeShow: 0
    actions: []
  - speaker: 3
    speakerName: "\u0413\u0413"
    text: "\u0427\u0442\u043E?"
    background: {fileID: 21300000, guid: 41bff0e74cdc3af49a90b77ae5be31da, type: 3}
    leftPortrait: {fileID: 21300000, guid: 8b1f0512e6f36324b895a8282b576de0, type: 3}
    rightPortrait: {fileID: 21300000, guid: 9887c52db6846274593998508bd203de, type: 3}
    leftActive: 1
    rightActive: 0
    useFade: 0
