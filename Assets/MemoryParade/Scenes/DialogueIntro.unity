  - speaker: 1
    speakerName: "\u0427\u0435\u0440\u043D\u044B\u0439 \u0431\u043E\u0433"
    text: "\u0422\u044B \u043C\u043D\u0435 \u043E\u0431\u044A\u044F\u0441\u043D\u0438\u0448\u044C,
      \u043F\u043E\u0447\u0435\u043C\u0443 \u043F\u043E\u0445\u0438\u0442\u0438\u043B
      \u044D\u0442\u043E\u0433\u043E \u043C\u0435\u0440\u0437\u043A\u043E\u0433\u043E
      \u0441\u0435\u0440\u043E\u0433\u043E \u0447\u0435\u043B\u043E\u0432\u0435\u0447\u0435\u0441\u043A\u043E\u0433\u043E
      \u0440\u0435\u0431\u0435\u043D\u043A\u0430?"
    background: {fileID: 21300000, guid: 41bff0e74cdc3af49a90b77ae5be31da, type: 3}
    leftPortrait: {fileID: 21300000, guid: 2ec1f9d991978b14aaa1555dfc0087d7, type: 3}
    rightPortrait: {fileID: 21300000, guid: 9887c52db6846274593998508bd203de, type: 3}
