    actions: []
  - speaker: 2
    speakerName: "\u0411\u0435\u043B\u044B\u0439 \u0431\u043E\u0433"
    text: "\u041E \u043D\u0435\u0442\u2026 \u0442\u043E\u043B\u044C\u043A\u043E \u043D\u0435
      \u0440\u0435\u0432\u0438! \u042F \u044D\u0442\u043E\u0433\u043E \u043D\u0435
      \u043F\u0435\u0440\u0435\u043D\u043E\u0448\u0443. \u0421\u0435\u0439\u0447\u0430\u0441
      \u0436\u0435 \u0432\u043E\u0437\u044C\u043C\u0438 \u0441\u0435\u0431\u044F
      \u0432 \u0440\u0443\u043A\u0438 \u0438 \u0434\u0430\u0439 \u043C\u043D\u0435
      \u0432\u0441\u0435 \u043E\u0431\u044A\u044F\u0441\u043D\u0438\u0442\u044C \u043C\u0430\u043B\u044C\u0446\u0443."
    background: {fileID: 21300000, guid: 41bff0e74cdc3af49a90b77ae5be31da, type: 3}
    leftPortrait: {fileID: 21300000, guid: 6a8fb94334ea19347b17c964a568cc25, type: 3}
    rightPortrait: {fileID: 21300000, guid: cb9a13413bbda0243964fc4401a2e9ab, type: 3}
