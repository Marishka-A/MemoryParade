  - speaker: 3
    speakerName: "\u0413\u0413"
    text: "\u0422\u043E\u043B\u044C\u043A\u043E \u0447\u0442\u043E \u044F \u0441\u043B\u044B\u0448\u0430\u043B
      \u0448\u0443\u043C, \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u043D\u043E,
      \u0447\u0442\u043E \u044D\u0442\u043E \u0431\u044B\u043B\u043E."
