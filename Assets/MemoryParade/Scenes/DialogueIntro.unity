  - speaker: 3
    speakerName: "\u0413\u0413"
    text: "\u0412\u043E\u043E\u0431\u0449\u0435-\u0442\u043E \u044F \u0432\u0441\u0435
      \u0441\u043B\u044B\u0448\u0443. \u0418 \u044F \u043D\u0435 \u0441\u0435\u0440\u044B\u0439!"
    background: {fileID: 21300000, guid: 41bff0e74cdc3af49a90b77ae5be31da, type: 3}
    leftPortrait: {fileID: 21300000, guid: dfde3493724dca44f8907cfe2bde76f9, type: 3}
    rightPortrait: {fileID: 21300000, guid: 9887c52db6846274593998508bd203de, type: 3}
    leftActive: 1
    rightActive: 0
    useFade: 0
    fadeDuration: 0.35
    shakeCamera: 0
    shakeDuration: 0.2
    shakeStrength: 8
    delayBeforeShow: 0
    actions: []
  - speaker: 2
    speakerName: "\u0411\u0435\u043B\u044B\u0439 \u0431\u043E\u0433"
    text: "\u0422\u0438\u0445\u043E, \u0432\u044B \u043E\u0431\u0430! \u0412\u043E-\u043F\u0435\u0440\u0432\u044B\u0445,
      \u044D\u0442\u043E \u0443\u0436\u0435 \u043D\u0435 \u0440\u0435\u0431\u0435\u043D\u043E\u043A,
      \u0430 \u0432\u043E-\u0432\u0442\u043E\u0440\u044B\u0445, \u0442\u044B \u0443\u0436\u0435
      \u0434\u043E\u043B\u0436\u0435\u043D \u0431\u044B\u0442\u044C \u0432 \u043A\u0443\u0440\u0441\u0435
      \u0441\u043E\u0431\u044B\u0442\u0438\u0439. \u0429\u0438\u0442 \u043B\u043E\u043F\u043D\u0443\u043B,
      \u043A\u0430\u043A \u043C\u044B\u043B\u044C\u043D\u044B\u0439 \u043F\u0443\u0437\u044B\u0440\u044C,
      \u044D\u0442\u0438 \u0442\u0432\u0430\u0440\u0438 \u0432\u0441\u0435-\u0442\u0430\u043A\u0438
      \u0432\u043E\u0440\u0432\u0430\u043B\u0438\u0441\u044C \u0432 \u043D\u0430\u0448
      \u043C\u0438\u043B\u044B\u0439 \u043C\u0438\u0440."
    background: {fileID: 21300000, guid: 41bff0e74cdc3af49a90b77ae5be31da, type: 3}
    leftPortrait: {fileID: 21300000, guid: dfde3493724dca44f8907cfe2bde76f9, type: 3}
    rightPortrait: {fileID: 21300000, guid: cb9a13413bbda0243964fc4401a2e9ab, type: 3}
    leftActive: 0
    rightActive: 1
    useFade: 0
    fadeDuration: 0.35
    shakeCamera: 0
    shakeDuration: 0.2
    shakeStrength: 8
    delayBeforeShow: 0
    actions: []
  - speaker: 1
    speakerName: "\u0427\u0435\u0440\u043D\u044B\u0439 \u0431\u043E\u0433"
    text: "\u0427\u0422\u041E\u041E\u041E\u041E? \u041A\u0410\u041A \u0429\u0418\u0422
      \u0421\u041B\u041E\u041C\u0410\u041B\u0421\u042F?"
    background: {fileID: 21300000, guid: 41bff0e74cdc3af49a90b77ae5be31da, type: 3}
    leftPortrait: {fileID: 21300000, guid: 2ec1f9d991978b14aaa1555dfc0087d7, type: 3}
    rightPortrait: {fileID: 21300000, guid: 9887c52db6846274593998508bd203de, type: 3}
    leftActive: 1
    rightActive: 0
    useFade: 0
    fadeDuration: 0.35
